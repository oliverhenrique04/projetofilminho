{
  "name": "filminho",
  "private": true,
  "version": "1.0.0",
  "description": "Filminho",
  "repository": "",
  "license": "UNLICENSED",
  "scripts": {
    "start": "concurrently \"npm:serve-backend\" \"npm:serve-frontend\"",
    "serve-frontend": "http-server ./www/ -o -c 1 -a localhost -p 8080",
    "serve-backend": "node backend/server.js",
    "build-cordova": "node ./build/build.mjs && cd cordova && npx cordova build",
    "build-cordova-ios": "node ./build/build.mjs && cd cordova && npx cordova build ios",
    "cordova-ios": "node ./build/build.mjs && cd cordova && npx cordova run ios",
    "build-cordova-android": "bash ./scripts/build-cordova-android.sh",
    "cordova-android": "bash ./scripts/build-cordova-android.sh && cd cordova && npx cordova run android",
    "test": "node --test --test-concurrency=1",
    "test:apis": "node scripts/test-public-apis.js",
    "postinstall": "cpy --flat ./node_modules/framework7-icons/fonts/*.* ./www/fonts/ && cpy --flat ./node_modules/material-icons/iconfont/*.* ./www/fonts/ && cpy --flat ./node_modules/framework7/*.js ./www/framework7 && cpy --flat ./node_modules/framework7/*.css ./www/framework7 && cpy --flat ./node_modules/framework7/*.map ./www/framework7"
  },
  "browserslist": [
    "IOS >= 15",
    "Safari >= 15",
    "last 5 Chrome versions",
    "last 5 Firefox versions"
  ],
  "dependencies": {
    "axios": "^1.13.6",
    "cordova-plugin-camera": "^8.0.0",
    "cordova-plugin-geolocation": "^5.0.0",
    "cors": "^2.8.6",
    "dom7": "^4.0.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "framework7": "^9.0.3",
    "framework7-icons": "^5.0.5",
    "material-icons": "^1.13.14",
    "skeleton-elements": "^4.0.1",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cordova": "^13.0.0",
    "cpy": "^13.2.1",
    "cpy-cli": "^7.0.0",
    "http-server": "^14.1.1",
    "jsdom": "^24.0.0",
    "rimraf": "^6.1.3"
  }
}
