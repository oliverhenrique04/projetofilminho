# Caminho absoluto para a chave do Firebase Admin SDK do backend
GOOGLE_APPLICATION_CREDENTIALS=/home/mrosa/.secrets/filminho-firebase-admin.json

# Prefixo público do backend publicado atrás do proxy reverso
APP_BASE_PATH=/filminho

# URL pública fixa consumida pelo app mobile/web
APP_PUBLIC_API_URL=https://nuted-ia.dev/filminho/api

# Banco local opcional para desenvolvimento
FILMINHO_DB=/home/mrosa/projetofilminho/backend/banco_filminho.json

# Porta opcional do backend
PORT=3000
